# ───────────────────────────────────────────────────────────────
#  Enayi Hotels — Frontend environment variables (EXAMPLE)
#  Vite inlines these at BUILD time, so set them BEFORE building.
#  On Render (Static Site), set them in the service's Environment tab.
# ───────────────────────────────────────────────────────────────

# Leave EMPTY for local dev (the Vite proxy forwards /api to localhost:8000).
# In production, set to your deployed backend URL (NO trailing slash):
VITE_API_URL=https://enayi-backend.onrender.com

# Public payment key (safe to expose — it's the publishable key)
VITE_PAYSTACK_PK=pk_test_xxxxxxxxxxxxxxxxxxxx
VITE_FLUTTERWAVE_PK=
VITE_STRIPE_PK=
VITE_PAYPAL_CLIENT_ID=
VITE_GOOGLE_MAPS_KEY=
