# ───────────────────────────────────────────────────────────────
#  Enayi Hotels — Backend environment variables (EXAMPLE / TEMPLATE)
#  Copy to ".env" for local dev. On Render, set these in the
#  service's "Environment" tab instead (do NOT commit real secrets).
# ───────────────────────────────────────────────────────────────

# ── Core ──
DEBUG=False
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.onrender.com

# ── Database (Render injects DATABASE_URL automatically via the Blueprint) ──
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL_REQUIRE=True

# ── Security (production) ──
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── Redis (LEAVE BLANK — not required; app falls back to local memory) ──
REDIS_URL=

# ── Email (optional; OTP send fails silently if blank) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Enayi Hotels <noreply@enayihotels.com>

# ── Payments (test keys for the trial) ──
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# ── AI (optional) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Hotel info ──
FRONTEND_URL=https://enayi-frontend.onrender.com
